GMAIL_CLIENT_ID=          # Google OAuth2 client ID
GMAIL_CLIENT_SECRET=      # Google OAuth2 client secret
GMAIL_REFRESH_TOKEN=      # OAuth2 refresh token for Gmail access
OPENAI_API_KEY=           # OpenAI API key (gpt-4o + o3)
TELEGRAM_BOT_TOKEN=       # Violet bot token
TELEGRAM_CHAT_ID=         # Telegram group chat ID (negative number)
TELEGRAM_THREAD_ID=       # Plutus topic thread ID in the group
API_BEARER_TOKEN=         # Bearer token for REST API + MCP auth
DATABASE_PATH=            # SQLite file path (/data/plutus.db on Railway)
POLL_INTERVAL_MINS=       # Gmail poll interval, default 10
AUTO_INFERENCE_ENABLED=   # "false" pauses automatic AI interpretation; defaults to enabled
AUTO_INFERENCE_INTERVAL_MINS= # Retry/pending queue interval, default 5
AUTO_INFERENCE_MIN_CONFIDENCE= # Auto-persist threshold, default 0.75
INFERENCE_MODEL=          # OpenAI model for transaction interpretation, default gpt-4o
WEBHOOK_URL=              # Public URL for Telegram webhook, e.g. https://finance.aniketraj.me
TELEGRAM_WEBHOOK_SECRET=  # Secret token Telegram echoes back on webhook calls, for request verification
PORT=                     # Fastify port, default 3000
NODE_ENV=                 # "production" on Railway — gates webhook registration
