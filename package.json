{
  "name": "plutus",
  "version": "1.1.1",
  "description": "Personal finance tracker that reads Gmail transaction alerts and communicates via Telegram",
  "main": "dist/index.js",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "test": "node --test tests/*.test.cjs",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "poll:once": "ts-node scripts/poll-once.ts",
    "enrich:one": "ts-node scripts/enrich-one.ts",
    "envelope:state": "ts-node scripts/envelope-state.ts",
    "envelope:setup": "ts-node scripts/envelope-setup.ts",
    "envelope:rollover": "ts-node scripts/envelope-rollover.ts",
    "envelope:apply": "ts-node scripts/envelope-apply.ts",
    "correlate:check": "ts-node scripts/correlate-check.ts",
    "correlate:force": "ts-node scripts/correlate-force.ts",
    "api:test": "ts-node scripts/api-test.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.1",
    "googleapis": "^144.0.0",
    "nanoid": "^3.3.16",
    "node-cron": "^3.0.3",
    "node-html-parser": "^9.0.0",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^4.67.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.16.10",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.7",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
